# ── Normalisation des fins de ligne ─────────────────────────────────────────
# Tous les fichiers texte sont normalisés en LF dans le dépôt
* text=auto eol=lf

# Fichiers texte explicites
*.kt        text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.gradle    text eol=lf
*.kts       text eol=lf
*.pro       text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.properties text eol=lf
*.html      text eol=lf

# ── Fichiers binaires (pas de conversion, pas de diff texte) ─────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.apk       binary
*.aab       binary
*.jks       binary
*.keystore  binary
*.jar       binary
*.aar       binary
*.so        binary
*.zip       binary

# ── Scripts Gradle Wrapper — exécutables sur Unix ────────────────────────────
gradlew     text eol=lf
gradlew.bat text eol=crlf
