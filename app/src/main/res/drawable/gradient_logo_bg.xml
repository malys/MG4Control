<?xml version="1.0" encoding="utf-8"?>
<!--
    Fond dégradé pour le logo en thème clair.
    Gauche : sombre (#1C1C1E) → Droite : transparent
    Permet de faire ressortir les lettres blanches "MG" sur le fond blanc de la top-bar.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="#CC1C1C1E"
        android:endColor="#00FFFFFF" />
</shape>
