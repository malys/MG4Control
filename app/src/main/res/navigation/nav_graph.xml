<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <!-- Écran principal unique (Drive + Regen + ADAS + Climat + Alertes) -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.mg4.control.ui.DashboardFragment"
        android:label="Dashboard" />

    <!-- Profils de conduite (bouton PROFILS dans la top-bar) -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.mg4.control.ui.ProfileFragment"
        android:label="@string/nav_profiles" />

    <!-- Réglages (bouton RÉGLAGES dans la top-bar) -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.mg4.control.ui.SettingsFragment"
        android:label="@string/nav_settings" />

</navigation>
