<?xml version="1.0" encoding="utf-8"?>
<!--
    Page 1 du dashboard — Sécurité (AEB) + Assistant de sortie de voie (ELK)
    Carte AEB  : Toggle ON/OFF | Mode (Alerte / Al.+Freinage) | Sensibilité (3 niveaux)
    Carte ELK  : Toggle ON/OFF | Mode d'assistance (3 choix)  | Sensibilité (3 choix)
    La carte AEB est masquée en visibility=gone par défaut (code la montre pour SWI133).
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dash_bg"
    android:padding="12dp">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  CARTE : Anticollision avant (AEB) — SWI133 uniquement            -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/aeb_card_page2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/aeb_card_title"
            android:textColor="@color/dash_text_lo"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="7dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_border" />

        <!-- Contenu : 3 colonnes — Toggle | Mode | Sensibilité -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- ── Colonne 1 : Activation ────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/elk_section_toggle"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center">

                    <Switch
                        android:id="@+id/switch_aeb_p2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Colonne 2 : Mode ───────────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/elk_section_mode"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <Button
                    android:id="@+id/btn_aeb_alarm_p2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/adas_aeb_alarm"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_aeb_alarm_brake_p2"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/adas_aeb_alarm_brake"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

            </LinearLayout>

            <!-- ── Colonne 3 : Sensibilité ───────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/aeb_section_sensitivity"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <Button
                    android:id="@+id/btn_aeb_sen_low"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/aeb_sensitivity_low"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_aeb_sen_standard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/aeb_sensitivity_standard"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_aeb_sen_high"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/aeb_sensitivity_high"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!--  CARTE : Assistant de sortie de voie (ELK)                       -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/bg_card_rounded">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/elk_card_title"
            android:textColor="@color/dash_text_lo"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="7dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_border" />

        <!-- Contenu : 3 colonnes — Toggle | Mode | Sensibilité -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="10dp">

            <!-- ── Colonne 1 : Activation ────────────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/elk_section_toggle"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:gravity="center">

                    <Switch
                        android:id="@+id/switch_elk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Colonne 2 : Mode d'assistance ─────────────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/elk_section_mode"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <Button
                    android:id="@+id/btn_elk_alert"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/elk_mode_alert"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_elk_assist"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/elk_mode_assist"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_elk_emergency"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/elk_mode_emergency"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

            </LinearLayout>

            <!-- ── Colonne 3 : Sensibilité des alertes ───────────── -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/bg_section_rounded"
                android:padding="9dp"
                android:layout_marginStart="5dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/elk_section_sensitivity"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingBottom="5dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border"
                    android:layout_marginBottom="5dp" />

                <Button
                    android:id="@+id/btn_elk_sen_low"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/elk_sensitivity_low"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_elk_sen_standard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginBottom="3dp"
                    android:text="@string/elk_sensitivity_standard"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

                <Button
                    android:id="@+id/btn_elk_sen_high"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="@string/elk_sensitivity_high"
                    android:textColor="@color/text_secondary"
                    android:backgroundTint="@color/dash_btn"
                    android:textSize="10sp"
                    android:textAllCaps="true" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
