<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog mise à jour — style dark dashboard
    3 groupes commutables :
      group_info     : infos version + boutons d'action (affiché par défaut)
      group_progress : barre de progression pendant le téléchargement
      group_manual   : instructions + QR code pour installation manuelle
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/dash_card"
    android:minWidth="680dp">

    <!-- En-tête -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/update_available_title"
        android:textColor="@color/dash_text_lo"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dash_border" />

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  GROUP INFO (affiché par défaut)                          -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/group_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <!-- Versions : vX.X  →  vX.X -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_section_rounded"
            android:padding="12dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/update_current_label"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tv_version_from"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v?"
                    android:textColor="@color/text_secondary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="→"
                android:textColor="@color/dash_accent"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/update_new_label"
                    android:textColor="@color/dash_accent"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tv_version_to"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="v?"
                    android:textColor="@color/dash_accent"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </LinearLayout>

        <!-- Notes de version -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_rounded"
            android:padding="10dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_release_notes_label"
                android:textColor="@color/dash_text_lo"
                android:textSize="9sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:paddingBottom="5dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border"
                android:layout_marginBottom="6dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:fadeScrollbars="false"
                android:overScrollMode="ifContentScrolls">

                <TextView
                    android:id="@+id/tv_release_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

            </ScrollView>

        </LinearLayout>

        <!-- Avertissement données mobiles (caché si WiFi) -->
        <LinearLayout
            android:id="@+id/row_data_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_section_rounded"
            android:padding="10dp"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/update_data_warning"
                android:textColor="@color/dash_warn"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Hint : N mises à jour non installées (visible si skippedCount > 0) -->
        <TextView
            android:id="@+id/tv_skip_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/dash_warn"
            android:textSize="10sp"
            android:gravity="start"
            android:layout_marginBottom="6dp"
            android:visibility="gone" />

        <!-- Boutons d'action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- Ne plus me rappeler — poussé à gauche via spacer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_update_skip"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/update_skip_btn"
                android:textColor="@color/dash_warn"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:backgroundTint="@color/dash_btn"
                app:strokeColor="@color/dash_warn"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_update_later"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:text="@string/update_later_btn"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:backgroundTint="@color/dash_btn"
                app:strokeColor="@color/dash_border"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_update_manual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:text="@string/update_manual_btn"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:backgroundTint="@color/dash_btn"
                app:strokeColor="@color/dash_border"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_update_auto"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="@string/update_auto_btn"
                android:textColor="@color/dash_accent"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:backgroundTint="@color/dash_accent_dim"
                app:strokeColor="@color/dash_accent"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  GROUP PROGRESS (téléchargement + installation)           -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/group_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_progress_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/update_downloading"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_download"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/update_cancel"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:backgroundTint="@color/dash_btn"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!--  GROUP MANUEL (QR code + instructions)                    -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/group_manual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Instructions (colonne gauche) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_manual_title"
                android:textColor="@color/dash_text_lo"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/tv_manual_instructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update_manual_instructions"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="8dp" />

            <!-- Chemin local de l'APK téléchargé (visible uniquement après téléchargement) -->
            <TextView
                android:id="@+id/tv_apk_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/dash_accent"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="14dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_close_manual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/update_close"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:backgroundTint="@color/dash_btn"
                app:strokeColor="@color/dash_border"
                app:strokeWidth="1dp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- QR code + lien (colonne droite) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/iv_update_qr"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="#FFFFFF"
                android:padding="6dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_update_gh_link"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/update_gh_releases_link"
                android:textColor="@color/dash_accent"
                android:textSize="11sp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

    <!-- Padding bas -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp" />

</LinearLayout>
