<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="#111111">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/console_title"
            android:textColor="#AAFFAA"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btn_clear_console"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/console_clear"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

    <!-- Hardware status -->
    <TextView
        android:id="@+id/console_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1A0D"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.3" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333" />

    <!-- Log output -->
    <ScrollView
        android:id="@+id/console_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/console_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.25"
            android:textIsSelectable="true" />

    </ScrollView>

</LinearLayout>
