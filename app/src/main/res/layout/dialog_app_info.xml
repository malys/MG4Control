<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog "À propos / Infos" — style dark dashboard
    Titre + séparateur en haut, contenu 2 colonnes, bouton Fermer en bas
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:minWidth="720dp">

    <!-- ── En-tête ─────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/info_title"
        android:textColor="@color/dash_text_lo"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dash_border" />

    <!-- ── Corps : 2 colonnes ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp">

        <!-- Colonne gauche : infos app -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="24dp">

            <!-- Nom app -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <!-- Basé sur DriveHub Dort -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_based_on"
                android:textColor="@color/dash_text_lo"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- Version -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/info_version_label"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="13sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tv_app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border"
                android:layout_marginBottom="12dp" />

            <!-- Firmware -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_firmware_label"
                android:textColor="@color/dash_text_lo"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_firmware_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_firmware_loading"
                android:textColor="@color/dash_accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Séparateur vertical -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/dash_border"
            android:layout_marginEnd="24dp" />

        <!-- Colonne droite : 2 QR codes côte à côte -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- QR codes : GitHub | GitLab -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <!-- GitHub -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:id="@+id/iv_qr_code_github"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:scaleType="fitCenter"
                        android:background="#FFFFFFFF"
                        android:padding="4dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_github_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_github_link"
                        android:textColor="@color/dash_accent"
                        android:textSize="13sp"
                        android:textStyle="italic"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- GitLab -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="8dp">

                    <ImageView
                        android:id="@+id/iv_qr_code_gitlab"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:scaleType="fitCenter"
                        android:background="#FFFFFFFF"
                        android:padding="4dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_gitlab_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/info_gitlab_link"
                        android:textColor="@color/dash_accent"
                        android:textSize="13sp"
                        android:textStyle="italic"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_border"
                android:layout_marginBottom="12dp" />

            <!-- Made with love -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_made_with_love"
                android:textColor="@color/dash_text_lo"
                android:textSize="13sp"
                android:gravity="center" />

            <!-- Remerciements spéciaux -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_special_thanks"
                android:textColor="@color/dash_text_lo"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── Pied de page : bouton Fermer ───────────────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dash_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_info_close"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="@string/info_close"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:backgroundTint="@color/dash_btn"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

</LinearLayout>
