<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Steering heat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp"
            android:background="@color/bg_card"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/climate_steering_heat"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <Switch
                android:id="@+id/switch_steering_heat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Seat Left -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/climate_seat_left"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_seat_left_0"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_off"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_seat_left_1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_level_1"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_seat_left_2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_level_2"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_seat_left_3"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_level_3"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Seat Right -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/climate_seat_right"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_seat_right_0"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_off"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_seat_right_1"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_level_1"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_seat_right_2"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_level_2"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_seat_right_3"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/climate_level_3"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
