<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:padding="16dp">

    <!-- Titre -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_language_pick_title"
        android:textColor="@color/dash_text_lo"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:letterSpacing="0.12"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="14dp" />

    <!-- Ligne 1 : FR | EN | DE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_fr"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="@string/settings_language_fr"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@color/dash_btn"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dash_border"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_en"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:text="@string/settings_language_en"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@color/dash_btn"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dash_border"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_de"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="@string/settings_language_de"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@color/dash_btn"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dash_border"
            app:cornerRadius="10dp" />

    </LinearLayout>

    <!-- Ligne 2 : ES | PT | IT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_es"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="@string/settings_language_es"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@color/dash_btn"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dash_border"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_pt"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:text="@string/settings_language_pt"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@color/dash_btn"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dash_border"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_it"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="@string/settings_language_it"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:backgroundTint="@color/dash_btn"
            app:strokeWidth="1dp"
            app:strokeColor="@color/dash_border"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>
