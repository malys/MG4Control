<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Drive Mode section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drive_section_mode"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_eco"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/drive_eco"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/accent_eco"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_normal"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/drive_normal"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_sport"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/drive_sport"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_snow"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/drive_snow"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_custom"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/drive_custom"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Regen section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drive_section_regen"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_regen_off"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/regen_off"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_regen_low"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/regen_low"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_regen_medium"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/regen_medium"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_regen_high"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/regen_high"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_regen_adaptive"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/regen_adaptive"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_regen_one_pedal"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/regen_one_pedal"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/bg_button"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
