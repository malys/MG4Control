<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dash_bg"
    android:padding="14dp">

    <!-- Liste des profils -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_profiles"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="10dp"
        android:clipToPadding="false" />

    <!-- Bouton Nouveau profil -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_profile"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginBottom="8dp"
        android:text="@string/profile_add"
        android:textColor="@color/dash_accent"
        android:textSize="12sp"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        app:backgroundTint="@color/dash_accent_dim"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dash_accent"
        app:cornerRadius="10dp" />

    <!-- Bouton Fermer -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_profiles"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="@string/nav_close"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        app:backgroundTint="@color/dash_btn"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dash_border"
        app:cornerRadius="10dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconTint="@color/dash_text_lo"
        app:iconGravity="textStart" />

</LinearLayout>
