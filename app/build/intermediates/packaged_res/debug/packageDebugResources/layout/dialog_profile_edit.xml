<?xml version="1.0" encoding="utf-8"?>
<!--
    Dialog création / édition de profil — style dark dashboard
    Structure :
      En-tête  : titre dynamique (New / Edit) + séparateur
      Contenu  : ScrollView → 2 colonnes (Gauche: Nom + Drive + Regen / Droite: Volant + Sièges + ADAS + Défaut)
      Pied de page : boutons Annuler / Enregistrer
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:minWidth="860dp">

    <!-- ── En-tête ─────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/profile_add"
        android:textColor="@color/dash_text_lo"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:textAllCaps="true"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="14dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dash_border" />

    <!-- ── Contenu scrollable ──────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp">

            <!-- ════════════════════════════════════════════════════════ -->
            <!--  COLONNE GAUCHE : Nom + Drive mode + Regen              -->
            <!-- ════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <!-- ── Nom du profil ──────────────────────────────── -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/profile_name_hint"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:maxLength="30"
                        android:inputType="textCapSentences" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Section Mode de conduite ───────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/drive_section_mode"
                        android:textColor="@color/dash_text_lo"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="5dp" />

                    <!-- Rangée 1 : ECO  NORMAL  SPORT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_drive_eco_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/drive_eco"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_drive_normal_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/drive_normal"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_drive_sport_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/drive_sport"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                    <!-- Rangée 2 : SNOW  CUSTOM -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_drive_snow_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/drive_snow"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_drive_custom_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/drive_custom"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Section Régénération ────────────────────────── -->
                <LinearLayout
                    android:id="@+id/section_regen_dialog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/drive_section_regen"
                        android:textColor="@color/dash_text_lo"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="5dp" />

                    <!-- Rangée 1 : OFF  FAIBLE  MOYEN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_regen_off_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/regen_off"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_regen_low_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/regen_low"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_regen_medium_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/regen_medium"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                    <!-- Rangée 2 : FORT  ADAPT.  1 PÉD. -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_regen_high_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/regen_high"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_regen_adaptive_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp"
                            android:text="@string/regen_adaptive_short"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_regen_one_pedal_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/regen_one_pedal_short"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Séparateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/dash_border"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="16dp" />

            <!-- ════════════════════════════════════════════════════════ -->
            <!--  COLONNE DROITE : Volant + Sièges + ADAS + Défaut       -->
            <!-- ════════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- ── Section Volant chauffant ───────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/climate_steering_heat"
                        android:textColor="@color/dash_text_lo"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textAllCaps="true"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="5dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_steer_off_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            android:text="@string/climate_off"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_steer_on_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            android:text="@string/climate_on"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Sièges gauche et droit (côte à côte) ──────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- Siège gauche -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_section_rounded"
                        android:padding="8dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/climate_seat_left"
                            android:textColor="@color/dash_text_lo"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:textAllCaps="true"
                            android:paddingBottom="5dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/dash_border"
                            android:layout_marginBottom="5dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:orientation="horizontal"
                            android:layout_marginBottom="3dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sl_0_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="2dp"
                                android:text="@string/climate_off"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sl_1_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:text="@string/climate_level_1"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sl_2_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="2dp"
                                android:text="@string/climate_level_2"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sl_3_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:text="@string/climate_level_3"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Siège droit -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_section_rounded"
                        android:padding="8dp"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/climate_seat_right"
                            android:textColor="@color/dash_text_lo"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.12"
                            android:textAllCaps="true"
                            android:paddingBottom="5dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/dash_border"
                            android:layout_marginBottom="5dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:orientation="horizontal"
                            android:layout_marginBottom="3dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sr_0_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="2dp"
                                android:text="@string/climate_off"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sr_1_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:text="@string/climate_level_1"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="38dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sr_2_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginEnd="2dp"
                                android:text="@string/climate_level_2"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_sr_3_d"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:text="@string/climate_level_3"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"
                                android:textAllCaps="true"
                                android:backgroundTint="@color/dash_btn"
                                app:strokeColor="@color/dash_border"
                                app:strokeWidth="1dp"
                                app:cornerRadius="6dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- ═══ ADAS SWI133 (Alertes + OFF / LIM. / AUTO / ACC / ICA) ═══ -->
                <LinearLayout
                    android:id="@+id/adas_section_swi133"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ADAS"
                        android:textColor="@color/dash_text_lo"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/adas_overspeed_alarm"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                        <Switch android:id="@+id/sw_overspeed_alarm"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="7dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/adas_speed_limit_tone"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                        <Switch android:id="@+id/sw_speed_limit_tone"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Mode ADAS rangée 1 : OFF / LIM. / AUTO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:orientation="horizontal"
                        android:layout_marginBottom="3dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_off_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginEnd="2dp"
                            android:text="@string/adas_off"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_lim_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                            android:text="@string/adas_limiteur_short"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_auto_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginStart="2dp"
                            android:text="@string/adas_auto"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                    </LinearLayout>

                    <!-- Mode ADAS rangée 2 : ACC / ICA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_acc_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginEnd="2dp"
                            android:text="@string/adas_acc"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_ica_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginStart="2dp"
                            android:text="@string/adas_ica"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                        <!-- Spacer alignement sur 3 colonnes -->
                        <View android:layout_width="0dp" android:layout_height="0dp"
                            android:layout_weight="1" android:layout_marginStart="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ═══ ADAS SWI68 (Alerte + Désactiver / ACC / TJA) ═══ -->
                <LinearLayout
                    android:id="@+id/adas_section_swi68"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="8dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ADAS"
                        android:textColor="@color/dash_text_lo"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:paddingBottom="5dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dash_border"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="7dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/adas_sound_warning"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                        <Switch android:id="@+id/sw_sound_warning"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_swi68_off_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginEnd="2dp"
                            android:text="@string/adas_desactiver"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_swi68_acc_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"
                            android:text="@string/adas_acc"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_adas_swi68_tja_d"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:layout_marginStart="2dp"
                            android:text="@string/adas_tja"
                            android:textColor="@color/text_secondary" android:textSize="10sp"
                            android:textAllCaps="true" android:backgroundTint="@color/dash_btn"
                            app:strokeColor="@color/dash_border" app:strokeWidth="1dp" app:cornerRadius="6dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- ── Toggle : Profil par défaut ─────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_section_rounded"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/profile_set_as_default"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/sw_set_default"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ── Pied de page : Annuler / Enregistrer ───────────────────── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/dash_border" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:text="@string/profile_cancel"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:backgroundTint="@color/dash_btn"
            app:strokeColor="@color/dash_border"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_save"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/profile_save"
            android:textColor="@color/dash_accent"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:backgroundTint="@color/dash_accent_dim"
            app:strokeColor="@color/dash_accent"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp" />

    </LinearLayout>

</LinearLayout>
