<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dash_bg"
    android:padding="14dp">

    <!-- ── Sections + boutons scrollables ────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Section LANGUE ──────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_language"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="7dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_lang_fr"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/settings_language_fr"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_lang_en"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/settings_language_en"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_lang_de"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="@string/settings_language_de"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_lang_es"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/settings_language_es"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_lang_pt"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/settings_language_pt"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_lang_it"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="@string/settings_language_it"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Section ÉCRAN PAR DÉFAUT ─────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_default_screen"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="7dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_default_dashboard"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="@string/settings_default_screen_dashboard"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_default_profiles"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:text="@string/nav_profiles"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_default_shortcuts"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:text="@string/nav_shortcuts"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Section APPARENCE ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_theme"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="7dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_auto"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/settings_theme_auto"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_dark"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/settings_theme_dark"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/ic_menu_month"
                        app:iconTint="@color/dash_text_lo"
                        app:iconSize="16dp"
                        app:iconGravity="textStart" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_theme_light"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="@string/settings_theme_light"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/dash_btn"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/dash_border"
                        app:cornerRadius="8dp"
                        app:icon="@android:drawable/ic_menu_today"
                        app:iconTint="@color/dash_text_lo"
                        app:iconSize="16dp"
                        app:iconGravity="textStart" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Section RÉGLAGES SUPPLÉMENTAIRES ───────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_auto_apply"
                    android:textColor="@color/dash_text_lo"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:textAllCaps="true"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="7dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_auto_apply_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/switch_auto_apply"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/dash_border" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_auto_update_desc"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Switch
                        android:id="@+id/switch_auto_update"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Boutons MAJ (2 colonnes : Vérifier | Nettoyer) ──────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_check_update"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/btn_check_update"
                    android:textColor="@color/dash_accent"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    app:backgroundTint="@color/dash_accent_dim"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/dash_accent"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/stat_sys_download"
                    app:iconTint="@color/dash_accent"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clean_apk"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/btn_clean_apk"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    app:backgroundTint="@color/dash_btn"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/dash_border"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="@color/dash_text_lo"
                    app:iconGravity="textStart" />

            </LinearLayout>

            <!-- ── Bouton DIAGNOSTIC (caché — 5 clics sur "Vérifier les mises à jour") ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_diagnostic"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                android:text="@string/btn_diagnostic"
                android:textColor="@color/dash_warn"
                android:textSize="12sp"
                android:letterSpacing="0.06"
                android:textAllCaps="true"
                app:backgroundTint="@color/dash_warn_dim"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dash_warn"
                app:cornerRadius="10dp"
                app:icon="@android:drawable/ic_menu_info_details"
                app:iconTint="@color/dash_warn"
                app:iconGravity="textStart" />

            <!-- ── Bouton INFOS ──────────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_infos"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="8dp"
                android:text="@string/btn_infos"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.06"
                android:textAllCaps="true"
                app:backgroundTint="@color/dash_btn"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dash_border"
                app:cornerRadius="10dp"
                app:icon="@android:drawable/ic_dialog_info"
                app:iconTint="@color/dash_text_lo"
                app:iconGravity="textStart" />

        </LinearLayout>

    </ScrollView>

    <!-- ── Bouton FERMER — fixe en bas ───────────────────────────────── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_settings"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:text="@string/nav_close"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        app:backgroundTint="@color/dash_btn"
        app:strokeWidth="1dp"
        app:strokeColor="@color/dash_border"
        app:cornerRadius="10dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconTint="@color/dash_text_lo"
        app:iconGravity="textStart" />

</LinearLayout>
